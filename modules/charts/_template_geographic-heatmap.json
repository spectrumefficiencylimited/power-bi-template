{
  "module": {
    "name": "_[Chart Display Name]_",
    "type": "map",
    "category": "charts",
    "description": "_[Geographic visualization purpose and usage description]_",
    "version": "1.0",
    "author": "_[Creator or team name]_",
    "created": "_[ISO date format: YYYY-MM-DD]_",
    "dependencies": [
      "_[Geographic reference table]_",
      "_[Primary data table]_",
      "_[Location table]_"
    ],
    "measures_required": [
      "_[Primary measure for size/intensity]_",
      "_[Secondary measure for color gradient]_"
    ],
    "config": {
      "visualType": "map",
      "objects": {
        "general": [
          {
            "properties": {
              "formatString": {
                "expr": {
                  "Literal": {
                    "Value": "_[Number format: 0.0%|#,0|etc]_"
                  }
                }
              }
            }
          }
        ],
        "legend": [
          {
            "properties": {
              "show": {
                "expr": {
                  "Literal": {
                    "Value": "true"
                  }
                }
              },
              "position": {
                "expr": {
                  "Literal": {
                    "Value": "'_[Right|Bottom|Top|Left]_'"
                  }
                }
              },
              "showTitle": {
                "expr": {
                  "Literal": {
                    "Value": "true"
                  }
                }
              },
              "fontFamily": {
                "expr": {
                  "Literal": {
                    "Value": "'_[Organization font family]_'"
                  }
                }
              }
            }
          }
        ],
        "dataPoint": [
          {
            "properties": {
              "defaultColor": {
                "solid": {
                  "color": {
                    "expr": {
                      "Literal": {
                        "Value": "'_[Default color for data points]_'"
                      }
                    }
                  }
                }
              },
              "categoryGradient": {
                "startColor": {
                  "solid": {
                    "color": {
                      "expr": {
                        "Literal": {
                          "Value": "'_[Gradient start color]_'"
                        }
                      }
                    }
                  }
                },
                "endColor": {
                  "solid": {
                    "color": {
                      "expr": {
                        "Literal": {
                          "Value": "'_[Gradient end color]_'"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "bubbles": [
          {
            "properties": {
              "bubbleSize": {
                "expr": {
                  "Literal": {
                    "Value": "_[Bubble size percentage]_L"
                  }
                }
              }
            }
          }
        ]
      },
      "activeProjections": {
        "Location": [
          {
            "Column": {
              "Expression": {
                "SourceRef": {
                  "Entity": "_[Geographic table name]_"
                }
              },
              "Property": "_[Location field: Postcode|State|Country]_"
            }
          }
        ],
        "Size": [
          {
            "Measure": {
              "Expression": {
                "SourceRef": {
                  "Entity": "_[Data table name]_"
                }
              },
              "Property": "_[Size measure name]_"
            }
          }
        ],
        "Gradient": [
          {
            "Measure": {
              "Expression": {
                "SourceRef": {
                  "Entity": "_[Data table name]_"
                }
              },
              "Property": "_[Color measure name]_"
            }
          }
        ]
      },
      "positioning": {
        "width": "_[Default width in pixels]_",
        "height": "_[Default height in pixels]_",
        "z_index": 1
      }
    },
    "organizational_branding": {
      "color_palette": [
        "_[Light color for low values]_",
        "_[Medium color for average values]_", 
        "_[Dark color for high values]_"
      ],
      "font_family": "_[Standard font family]_",
      "map_style": "_[Satellite|Road|Terrain]_"
    },
    "responsive_behavior": {
      "desktop": {
        "width": "_[Desktop width]_",
        "height": "_[Desktop height]_",
        "zoom_level": "_[Default zoom level]_",
        "show_legend": "true"
      },
      "tablet": {
        "width": "_[Tablet width]_",
        "height": "_[Tablet height]_",
        "zoom_level": "_[Tablet zoom level]_",
        "show_legend": "false"
      },
      "mobile": {
        "width": "_[Mobile width]_",
        "height": "_[Mobile height]_",
        "zoom_level": "_[Mobile zoom level]_",
        "show_legend": "false"
      }
    },
    "drill_through": {
      "enabled": "_[true|false]_",
      "target_page": "_[Target page name]_",
      "fields": ["_[Field 1]_", "_[Field 2]_", "_[Field 3]_"]
    },
    "accessibility": {
      "color_blind_patterns": "_[Alternative visual patterns for color accessibility]_",
      "high_contrast_mode": "_[High contrast color scheme]_",
      "aria_labels": "_[Map description for screen readers]_"
    },
    "usage_notes": {
      "placement": "_[Recommended placement in report]_",
      "interactions": "_[Cross-filtering and drill-through behavior]_",
      "mobile_behavior": "_[Mobile-specific adaptations]_",
      "performance": "_[Performance considerations and load time impact]_"
    },
    "customization_options": {
      "color_scale": "_[Adjustable color gradient options]_",
      "bubble_size": "_[Can represent different metrics]_",
      "zoom_level": "_[Default focus region]_",
      "map_type": "_[Satellite|Terrain|Road map options]_"
    }
  }
}
